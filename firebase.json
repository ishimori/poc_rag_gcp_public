{
  "hosting": {
    "public": "ui/dist",
    "rewrites": [
      { "source": "/api/admin/**", "function": "admin" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "index.html",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      },
      {
        "source": "assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "firestore": {
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "runtime": "python312",
      "ignore": [
        ".git",
        ".git/**",
        ".github",
        ".github/**",
        ".venv",
        ".venv/**",
        "venv",
        "venv/**",
        "__pycache__",
        "__pycache__/**",
        "node_modules",
        "node_modules/**",
        "doc",
        "doc/**",
        "site",
        "site/**",
        "test-data",
        "test-data/**",
        "data_cache",
        "data_cache/**",
        "results",
        "results/**",
        "streamlit",
        "streamlit/**",
        "ui",
        "ui/**",
        "scripts",
        "scripts/**",
        ".env",
        ".env.*",
        "*.md",
        "*.lock",
        "mkdocs.yml",
        "pyproject.toml",
        ".claude",
        ".claude/**",
        ".playwright-mcp",
        ".playwright-mcp/**",
        ".ruff_cache",
        ".ruff_cache/**"
      ]
    }
  ]
}
